digraph BehaviorTree {
  rankdir=TB;
  node [fontsize=10, margin="0.15,0.07"];
  edge [arrowsize=0.7];

  // Legend
  subgraph cluster_legend {
    label="Legend"; fontname="Arial"; fontsize=10; style=rounded; color=gray;
    lc [label="Control", shape=box, style="rounded,filled", fillcolor="#FFD966", fontname="Arial", fontsize=9];
    ld [label="Decorator", shape=box, style="rounded,filled", fillcolor="#A4C2F4", fontname="Arial", fontsize=9];
    la [label="Action", shape=box, style="rounded,filled", fillcolor="#B6D7A8", fontname="Arial", fontsize=9];
    lk [label="Condition", shape=diamond, style=filled, fillcolor="#F4CCCC", fontname="Arial", fontsize=9];
    ls [label="SubTree", shape=box, style="rounded,filled,dashed", fillcolor="#D5A6BD", fontname="Arial", fontsize=9];
    lc -> ld -> la -> lk -> ls [style=invis];
  }

  // Tree: DockAndRecharge
  n0 [label="Sequence\n'dock_and_recharge'", shape="box", style="rounded,filled", fillcolor="#FFD966", fontname="Arial"];
  n1 [label="Navigate\n→ docking_station", shape="box", style="rounded,filled", fillcolor="#B6D7A8", fontname="Arial"];
  n0 -> n1;
  n2 [label="DockStatus\ntrue", shape="box", style="rounded,filled", fillcolor="#B6D7A8", fontname="Arial"];
  n0 -> n2;
  n3 [label="WaitForBatteryOK", shape="box", style="rounded,filled", fillcolor="#B6D7A8", fontname="Arial"];
  n0 -> n3;

  // Tree: RescueMission
  n4 [label="ReactiveSequence\n'fire_guard'", shape="box", style="rounded,filled", fillcolor="#FFD966", fontname="Arial"];
  n5 [label="CheckFireSafe", shape="diamond", style="filled", fillcolor="#F4CCCC", fontname="Arial"];
  n4 -> n5;
  n6 [label="Sequence\n'mission'", shape="box", style="rounded,filled", fillcolor="#FFD966", fontname="Arial"];
  n7 [label="Sequence\n'task1_survivor_rescue'", shape="box", style="rounded,filled", fillcolor="#FFD966", fontname="Arial"];
  n8 [label="ReactiveSequence", shape="box", style="rounded,filled", fillcolor="#FFD966", fontname="Arial"];
  n9 [label="ReactiveFallback", shape="box", style="rounded,filled", fillcolor="#FFD966", fontname="Arial"];
  n10 [label="CheckBatteryOK", shape="diamond", style="filled", fillcolor="#F4CCCC", fontname="Arial"];
  n9 -> n10;
  n11 [label="SubTree\nDockAndRecharge", shape="box", style="rounded,filled,dashed", fillcolor="#D5A6BD", fontname="Arial"];
  n9 -> n11;
  n8 -> n9;
  n12 [label="Timeout\n600s", shape="box", style="rounded,filled", fillcolor="#A4C2F4", fontname="Arial"];
  n13 [label="Navigate\n→ survivor", shape="box", style="rounded,filled", fillcolor="#B6D7A8", fontname="Arial"];
  n12 -> n13;
  n8 -> n12;
  n7 -> n8;
  n14 [label="DockStatus\nfalse", shape="box", style="rounded,filled", fillcolor="#B6D7A8", fontname="Arial"];
  n7 -> n14;
  n15 [label="Wait 1.0s", shape="box", style="rounded,filled", fillcolor="#B6D7A8", fontname="Arial"];
  n7 -> n15;
