<?xml version="1.0"?>
<robot name="rescue_robot">

	<material name="dark_gray">
		<color rgba="0.3 0.3 0.3 1.0"/>
	</material>
	<material name="black">
		<color rgba="0.05 0.05 0.05 1.0"/>
	</material>
	<material name="teal">
		<color rgba="0.0 0.5 0.5 1.0"/>
	</material>

	<!-- Base chassis: 0.4 x 0.3 x 0.15m box, 5kg -->
	<link name="base_link">
		<visual>
			<origin xyz="0 0 0.075" rpy="0 0 0"/>
			<geometry>
				<box size="0.4 0.3 0.15"/>
			</geometry>
			<material name="dark_gray"/>
		</visual>
		<collision>
			<origin xyz="0 0 0.075" rpy="0 0 0"/>
			<geometry>
				<box size="0.4 0.3 0.15"/>
			</geometry>
		</collision>
		<inertial>
			<origin xyz="0 0 0.075" rpy="0 0 0"/>
			<mass value="5.0"/>
			<inertia ixx="0.046875" ixy="0.0" ixz="0.0" iyy="0.076042" iyz="0.0" izz="0.104167"/>
		</inertial>
	</link>

	<!-- Left wheel: cylinder r=0.075, w=0.03, 0.3kg -->
	<link name="left_wheel">
		<visual>
			<origin xyz="0 0 0" rpy="-1.5708 0 0"/>
			<geometry>
				<cylinder radius="0.075" length="0.03"/>
			</geometry>
			<material name="black"/>
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="-1.5708 0 0"/>
			<geometry>
				<cylinder radius="0.075" length="0.03"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.3"/>
			<inertia ixx="0.000444" ixy="0.0" ixz="0.0" iyy="0.000444" iyz="0.0" izz="0.000844"/>
		</inertial>
	</link>

	<joint name="left_wheel_joint" type="continuous">
		<parent link="base_link"/>
		<child link="left_wheel"/>
		<origin xyz="-0.05 0.165 0.075" rpy="0 0 0"/>
		<axis xyz="0 1 0"/>
	</joint>

	<!-- Right wheel: cylinder r=0.075, w=0.03, 0.3kg -->
	<link name="right_wheel">
		<visual>
			<origin xyz="0 0 0" rpy="-1.5708 0 0"/>
			<geometry>
				<cylinder radius="0.075" length="0.03"/>
			</geometry>
			<material name="black"/>
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="-1.5708 0 0"/>
			<geometry>
				<cylinder radius="0.075" length="0.03"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.3"/>
			<inertia ixx="0.000444" ixy="0.0" ixz="0.0" iyy="0.000444" iyz="0.0" izz="0.000844"/>
		</inertial>
	</link>

	<joint name="right_wheel_joint" type="continuous">
		<parent link="base_link"/>
		<child link="right_wheel"/>
		<origin xyz="-0.05 -0.165 0.075" rpy="0 0 0"/>
		<axis xyz="0 1 0"/>
	</joint>

	<!-- Caster: sphere r=0.025, 0.1kg -->
	<link name="caster_wheel">
		<visual>
			<geometry>
				<sphere radius="0.025"/>
			</geometry>
			<material name="black"/>
		</visual>
		<collision>
			<geometry>
				<sphere radius="0.025"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.1"/>
			<inertia ixx="0.000025" ixy="0.0" ixz="0.0" iyy="0.000025" iyz="0.0" izz="0.000025"/>
		</inertial>
	</link>

	<joint name="caster_joint" type="fixed">
		<parent link="base_link"/>
		<child link="caster_wheel"/>
		<origin xyz="0.15 0 0.025" rpy="0 0 0"/>
	</joint>

	<!-- LiDAR: cylinder r=0.035, h=0.03, 0.15kg -->
	<link name="lidar_link">
		<visual>
			<geometry>
				<cylinder radius="0.035" length="0.03"/>
			</geometry>
			<material name="teal"/>
		</visual>
		<collision>
			<geometry>
				<cylinder radius="0.035" length="0.03"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.15"/>
			<inertia ixx="0.000057" ixy="0.0" ixz="0.0" iyy="0.000057" iyz="0.0" izz="0.000092"/>
		</inertial>
	</link>

	<joint name="lidar_joint" type="fixed">
		<parent link="base_link"/>
		<child link="lidar_link"/>
		<origin xyz="0 0 0.165" rpy="0 0 0"/>
	</joint>

	<!-- Camera: box 0.05 x 0.04 x 0.03, 0.1kg, revolute ±15° -->
	<link name="camera_link">
		<visual>
			<geometry>
				<box size="0.05 0.04 0.03"/>
			</geometry>
			<material name="teal"/>
		</visual>
		<collision>
			<geometry>
				<box size="0.05 0.04 0.03"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.1"/>
			<inertia ixx="0.000021" ixy="0.0" ixz="0.0" iyy="0.000028" iyz="0.0" izz="0.000034"/>
		</inertial>
	</link>

	<joint name="camera_joint" type="revolute">
		<parent link="base_link"/>
		<child link="camera_link"/>
		<origin xyz="0.2 0 0.12" rpy="0 0 0"/>
		<axis xyz="0 0 1"/>
		<limit lower="-0.2618" upper="0.2618" effort="1.0" velocity="1.0"/>
	</joint>

	<!-- IMU: no visual, just a sensor frame -->
	<link name="imu_link">
		<inertial>
			<mass value="0.02"/>
			<inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
		</inertial>
	</link>

	<joint name="imu_joint" type="fixed">
		<parent link="base_link"/>
		<child link="imu_link"/>
		<origin xyz="0 0 0.085" rpy="0 0 0"/>
	</joint>

	<!-- Gazebo DiffDrive plugin (replaces ros2_control for wheels) -->
	<gazebo>
		<plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
			<left_joint>left_wheel_joint</left_joint>
			<right_joint>right_wheel_joint</right_joint>
			<wheel_separation>0.33</wheel_separation>
			<wheel_radius>0.075</wheel_radius>
			<odom_publish_frequency>50</odom_publish_frequency>
			<topic>/cmd_vel_out</topic>
			<odom_topic>/odom</odom_topic>
			<tf_topic>/tf</tf_topic>
			<frame_id>odom</frame_id>
			<child_frame_id>base_link</child_frame_id>
		</plugin>
	</gazebo>

	<!-- Gazebo JointStatePublisher for TF -->
	<gazebo>
		<plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
			<topic>/joint_states</topic>
			<joint_name>left_wheel_joint</joint_name>
			<joint_name>right_wheel_joint</joint_name>
			<joint_name>camera_joint</joint_name>
		</plugin>
	</gazebo>

	<!-- LiDAR sensor: 360° scan -->
	<gazebo reference="lidar_link">
		<sensor name="lidar_sensor" type="gpu_lidar">
			<update_rate>10</update_rate>
			<topic>/scan</topic>
			<lidar>
				<scan>
					<horizontal>
						<samples>360</samples>
						<resolution>1</resolution>
						<min_angle>-3.14159</min_angle>
						<max_angle>3.14159</max_angle>
					</horizontal>
				</scan>
				<range>
					<min>0.12</min>
					<max>20.0</max>
					<resolution>0.01</resolution>
				</range>
			</lidar>
		</sensor>
	</gazebo>

	<!-- Camera sensor -->
	<gazebo reference="camera_link">
		<sensor name="front_camera" type="camera">
			<update_rate>15</update_rate>
			<topic>/camera/image_raw</topic>
			<camera>
				<horizontal_fov>1.047</horizontal_fov>
				<image>
					<width>640</width>
					<height>480</height>
					<format>R8G8B8</format>
				</image>
				<clip>
					<near>0.05</near>
					<far>50.0</far>
				</clip>
			</camera>
		</sensor>
	</gazebo>

	<!-- IMU sensor -->
	<gazebo reference="imu_link">
		<sensor name="imu_sensor" type="imu">
			<update_rate>50</update_rate>
			<topic>/imu/data</topic>
		</sensor>
	</gazebo>

</robot>
