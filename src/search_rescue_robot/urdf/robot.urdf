<?xml version="1.0"?>
<robot name="rescue_rover_a2">

	<material name="body_gray">
		<color rgba="0.32 0.34 0.37 1.0"/>
	</material>
	<material name="wheel_black">
		<color rgba="0.08 0.08 0.08 1.0"/>
	</material>
	<material name="sensor_cyan">
		<color rgba="0.10 0.55 0.60 1.0"/>
	</material>

	<!-- Main body: compact rectangular chassis. -->
	<link name="base_link">
		<visual>
			<origin xyz="0 0 0.055" rpy="0 0 0"/>
			<geometry>
				<box size="0.29 0.17 0.11"/>
			</geometry>
			<material name="body_gray"/>
		</visual>
		<collision>
			<origin xyz="0 0 0.055" rpy="0 0 0"/>
			<geometry>
				<box size="0.29 0.17 0.11"/>
			</geometry>
		</collision>
		<inertial>
			<origin xyz="0 0 0.055" rpy="0 0 0"/>
			<mass value="4.8"/>
			<inertia ixx="0.020" ixy="0.0" ixz="0.0" iyy="0.039" iyz="0.0" izz="0.046"/>
		</inertial>
	</link>

	<link name="left_wheel">
		<visual>
			<origin xyz="0 0 0" rpy="-1.5708 0 0"/>
			<geometry>
				<cylinder radius="0.07" length="0.035"/>
			</geometry>
			<material name="wheel_black"/>
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="-1.5708 0 0"/>
			<geometry>
				<cylinder radius="0.07" length="0.035"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.34"/>
			<inertia ixx="0.00087" ixy="0.0" ixz="0.0" iyy="0.00087" iyz="0.0" izz="0.00083"/>
		</inertial>
	</link>

	<joint name="left_wheel_joint" type="continuous">
		<parent link="base_link"/>
		<child link="left_wheel"/>
		<origin xyz="-0.06 0.102 0.07" rpy="0 0 0"/>
		<axis xyz="0 1 0"/>
	</joint>

	<link name="right_wheel">
		<visual>
			<origin xyz="0 0 0" rpy="-1.5708 0 0"/>
			<geometry>
				<cylinder radius="0.07" length="0.035"/>
			</geometry>
			<material name="wheel_black"/>
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="-1.5708 0 0"/>
			<geometry>
				<cylinder radius="0.07" length="0.035"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.34"/>
			<inertia ixx="0.00087" ixy="0.0" ixz="0.0" iyy="0.00087" iyz="0.0" izz="0.00083"/>
		</inertial>
	</link>

	<joint name="right_wheel_joint" type="continuous">
		<parent link="base_link"/>
		<child link="right_wheel"/>
		<origin xyz="-0.06 -0.102 0.07" rpy="0 0 0"/>
		<axis xyz="0 1 0"/>
	</joint>

	<link name="caster_wheel">
		<visual>
			<geometry>
				<sphere radius="0.028"/>
			</geometry>
			<material name="wheel_black"/>
		</visual>
		<collision>
			<geometry>
				<sphere radius="0.028"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.12"/>
			<inertia ixx="0.000038" ixy="0.0" ixz="0.0" iyy="0.000038" iyz="0.0" izz="0.000038"/>
		</inertial>
	</link>

	<joint name="caster_joint" type="fixed">
		<parent link="base_link"/>
		<child link="caster_wheel"/>
		<origin xyz="0.115 0 0.028" rpy="0 0 0"/>
	</joint>

	<link name="lidar_link">
		<visual>
			<geometry>
				<cylinder radius="0.032" length="0.03"/>
			</geometry>
			<material name="sensor_cyan"/>
		</visual>
		<collision>
			<geometry>
				<cylinder radius="0.032" length="0.03"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.18"/>
			<inertia ixx="0.000058" ixy="0.0" ixz="0.0" iyy="0.000058" iyz="0.0" izz="0.000092"/>
		</inertial>
	</link>

	<joint name="lidar_joint" type="fixed">
		<parent link="base_link"/>
		<child link="lidar_link"/>
		<origin xyz="-0.085 0 0.14" rpy="0 0 0"/>
	</joint>

	<link name="camera_link">
		<visual>
			<geometry>
				<box size="0.05 0.04 0.028"/>
			</geometry>
			<material name="sensor_cyan"/>
		</visual>
		<collision>
			<geometry>
				<box size="0.05 0.04 0.028"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.10"/>
			<inertia ixx="0.000019" ixy="0.0" ixz="0.0" iyy="0.000028" iyz="0.0" izz="0.000035"/>
		</inertial>
	</link>

	<joint name="camera_joint" type="revolute">
		<parent link="base_link"/>
		<child link="camera_link"/>
		<origin xyz="0.125 0 0.09" rpy="0 0 0"/>
		<axis xyz="0 0 1"/>
		<limit lower="-0.174533" upper="0.174533" effort="1.2" velocity="0.9"/>
	</joint>

	<!-- IMU frame intentionally has no visual/collision. -->
	<link name="imu_link">
		<inertial>
			<mass value="0.02"/>
			<inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
		</inertial>
	</link>

	<joint name="imu_joint" type="fixed">
		<parent link="base_link"/>
		<child link="imu_link"/>
		<origin xyz="0.0 0 0.066" rpy="0 0 0"/>
	</joint>

	<ros2_control name="GazeboSimSystem" type="system">
		<hardware>
			<plugin>gz_ros2_control/GazeboSimSystem</plugin>
		</hardware>

		<joint name="left_wheel_joint">
			<command_interface name="velocity"/>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>

		<joint name="right_wheel_joint">
			<command_interface name="velocity"/>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>

		<joint name="camera_joint">
			<command_interface name="position"/>
			<state_interface name="position"/>
			<state_interface name="velocity"/>
		</joint>
	</ros2_control>

	<gazebo>
		<plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
		</plugin>
	</gazebo>

	<gazebo reference="lidar_link">
		<sensor name="lidar_sensor" type="gpu_lidar">
			<update_rate>10</update_rate>
			<topic>/scan</topic>
			<lidar>
				<scan>
					<horizontal>
						<samples>360</samples>
						<resolution>1</resolution>
						<min_angle>-3.14159</min_angle>
						<max_angle>3.14159</max_angle>
					</horizontal>
				</scan>
				<range>
					<min>0.12</min>
					<max>20.0</max>
					<resolution>0.01</resolution>
				</range>
			</lidar>
		</sensor>
	</gazebo>

	<gazebo reference="camera_link">
		<sensor name="front_camera" type="camera">
			<update_rate>15</update_rate>
			<topic>/camera/image_raw</topic>
			<camera>
				<horizontal_fov>1.047</horizontal_fov>
				<image>
					<width>640</width>
					<height>480</height>
					<format>R8G8B8</format>
				</image>
				<clip>
					<near>0.05</near>
					<far>50.0</far>
				</clip>
			</camera>
		</sensor>
	</gazebo>

	<gazebo reference="imu_link">
		<sensor name="imu_sensor" type="imu">
			<update_rate>50</update_rate>
			<topic>/imu/data</topic>
		</sensor>
	</gazebo>

</robot>
