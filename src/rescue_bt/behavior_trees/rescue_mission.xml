<!--
  rescue_mission.xml
  The main behavior tree for the search and rescue mission.
  Uses BT.CPP format 4.

  The tree is structured so that fire safety is checked every tick
  (ReactiveSequence at the top level), and each navigation action
  is wrapped in a battery check that triggers docking if needed.
-->
<root BTCPP_format="4" main_tree_to_execute="RescueMission">

  <!-- DockAndRecharge: reusable subtree called when battery is low.
       Navigates to the docking station, sets docked=true so the battery
       simulator starts charging, then waits until the battery is full. -->
  <BehaviorTree ID="DockAndRecharge">
    <Sequence name="dock_and_recharge">
      <NavigateToWaypoint x="23.5" y="0.0" description="docking_station"/>
      <PublishDockStatus docked="true"/>
      <WaitForBatteryOK/>
    </Sequence>
  </BehaviorTree>

  <!-- Main mission tree -->
  <BehaviorTree ID="RescueMission">
    <!-- fire_guard: ReactiveSequence re-evaluates CheckFireSafe on every tick.
         If the robot gets too close to the fire, the whole mission halts. -->
    <ReactiveSequence name="fire_guard">
      <CheckFireSafe/>

      <Sequence name="mission">

        <!-- Task 1: Find the survivor, get the medical kit, deliver it back -->
        <Sequence name="task1_survivor_rescue">

          <!-- 1a. Go to the survivor location.
               The ReactiveFallback checks battery every tick during navigation.
               If CheckBatteryOK fails (battery low), it runs DockAndRecharge instead. -->
          <ReactiveSequence>
            <ReactiveFallback>
              <CheckBatteryOK/>
              <SubTree ID="DockAndRecharge"/>
            </ReactiveFallback>
            <Timeout msec="600000">
              <NavigateToWaypoint x="15.1" y="11.9" description="survivor"/>
            </Timeout>
          </ReactiveSequence>
          <!-- mark as undocked after arriving (in case we just came from charging) -->
          <PublishDockStatus docked="false"/>

          <!-- 1b. Pause at the survivor for 1 second -->
          <WaitSeconds seconds="1.0"/>

          <!-- 1c. Publish the survivor's position as a TF frame on the map -->
          <PublishObjectTF frame_name="survivor_location" x="15.1" y="13.4"/>

          <!-- 1d. Go pick up the medical kit -->
          <ReactiveSequence>
            <ReactiveFallback>
              <CheckBatteryOK/>
              <SubTree ID="DockAndRecharge"/>
            </ReactiveFallback>
            <Timeout msec="600000">
              <NavigateToWaypoint x="-6.3" y="-18.4" description="medical_kit"/>
            </Timeout>
          </ReactiveSequence>
          <PublishDockStatus docked="false"/>

          <!-- 1e. Bring the med kit back to the survivor -->
          <ReactiveSequence>
            <ReactiveFallback>
              <CheckBatteryOK/>
              <SubTree ID="DockAndRecharge"/>
            </ReactiveFallback>
            <Timeout msec="600000">
              <NavigateToWaypoint x="15.1" y="11.9" description="survivor_return"/>
            </Timeout>
          </ReactiveSequence>
          <PublishDockStatus docked="false"/>

        </Sequence>

        <!-- Task 2: Go to the dam and scan it with the camera -->
        <Sequence name="task2_dam_scan">

          <!-- 2a. Navigate to the dam -->
          <ReactiveSequence>
            <ReactiveFallback>
              <CheckBatteryOK/>
              <SubTree ID="DockAndRecharge"/>
            </ReactiveFallback>
            <Timeout msec="600000">
              <NavigateToWaypoint x="8.7" y="-13.1" description="dam"/>
            </Timeout>
          </ReactiveSequence>
          <PublishDockStatus docked="false"/>

          <!-- 2b. Sweep the camera: centre, then left (~10 deg), then right, then back to centre.
               0.1745 rad is roughly 10 degrees. Each position held for 2 seconds. -->
          <SetCameraAngle angle="0.0"/>
          <WaitSeconds seconds="2.0"/>
          <SetCameraAngle angle="0.1745"/>
          <WaitSeconds seconds="2.0"/>
          <SetCameraAngle angle="-0.1745"/>
          <WaitSeconds seconds="2.0"/>
          <SetCameraAngle angle="0.0"/>

        </Sequence>

        <!-- Task 5: Navigate to the building exit and wait there -->
        <Sequence name="task5_exit">

          <ReactiveSequence>
            <ReactiveFallback>
              <CheckBatteryOK/>
              <SubTree ID="DockAndRecharge"/>
            </ReactiveFallback>
            <Timeout msec="600000">
              <NavigateToWaypoint x="2.9" y="15.7" description="exit"/>
            </Timeout>
          </ReactiveSequence>
          <PublishDockStatus docked="false"/>

          <!-- Wait at exit for 5 seconds to confirm arrival -->
          <WaitSeconds seconds="5.0"/>

        </Sequence>

      </Sequence>
    </ReactiveSequence>
  </BehaviorTree>

</root>
