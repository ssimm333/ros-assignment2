<?xml version="1.0"?>
<root BTCPP_format="4" main_tree_to_execute="MainMission">

  <!-- ═══ MAIN MISSION ═══ -->
  <BehaviorTree ID="MainMission">
    <ReactiveSequence name="safety_monitor">
      <!-- Task 4: Fire safety — always checked first -->
      <CheckFireSafe fire_x="-14.2" fire_y="10.8" safe_distance="3.0"/>

      <!-- Battery-aware mission execution -->
      <ReactiveFallback name="battery_handler">
        <!-- Normal ops: run if battery OK -->
        <ReactiveSequence name="normal_ops">
          <CheckBatteryOK/>
          <Sequence name="all_tasks">
            <SubTree ID="Task1_MedicalKitToSurvivor"/>
            <SubTree ID="Task2_ScanDam"/>
            <SubTree ID="Task5_ExitBuilding"/>
          </Sequence>
        </ReactiveSequence>

        <!-- Task 3: Low battery — dock and recharge -->
        <SubTree ID="Task3_LowBattery"/>
      </ReactiveFallback>
    </ReactiveSequence>
  </BehaviorTree>

  <!-- ═══ TASK 1: Bring Medical Kit to Survivor (10 marks) ═══ -->
  <BehaviorTree ID="Task1_MedicalKitToSurvivor">
    <Sequence name="task1">
      <!-- 1. Navigate to survivor (stop 1m away) -->
      <NavigateToWaypoint x="14.1" y="13.4" theta="0.0"
                          description="approach survivor"/>
      <!-- 2. Wait 1 second -->
      <WaitSeconds duration="1.0"/>
      <!-- 3. Publish TF of survivor relative to spawn -->
      <PublishObjectTF object_name="survivor" x="15.1" y="13.4"/>
      <!-- 4. Navigate to medical kit -->
      <NavigateToWaypoint x="-6.3" y="-16.4" theta="-1.57"
                          description="go to medical kit"/>
      <!-- 5. Return to survivor -->
      <NavigateToWaypoint x="14.1" y="13.4" theta="0.0"
                          description="return to survivor"/>
    </Sequence>
  </BehaviorTree>

  <!-- ═══ TASK 2: Scan Dam for Damage (10 marks) ═══ -->
  <BehaviorTree ID="Task2_ScanDam">
    <Sequence name="task2">
      <!-- 1. Navigate to dam (stop 50cm away) -->
      <NavigateToWaypoint x="8.7" y="-11.1" theta="-1.57"
                          description="approach dam"/>
      <!-- 2. Aim camera at centre -->
      <SetCameraAngle angle="0.0"/>
      <WaitSeconds duration="0.5"/>
      <!-- 3. Rotate camera 10° left (0.1745 rad) -->
      <SetCameraAngle angle="0.1745"/>
      <WaitSeconds duration="0.5"/>
      <!-- 4. Rotate camera 10° right (-0.1745 rad) -->
      <SetCameraAngle angle="-0.1745"/>
      <WaitSeconds duration="0.5"/>
      <!-- Reset camera -->
      <SetCameraAngle angle="0.0"/>
    </Sequence>
  </BehaviorTree>

  <!-- ═══ TASK 3: Low Battery — Dock & Recharge (10 marks) ═══ -->
  <BehaviorTree ID="Task3_LowBattery">
    <Sequence name="task3">
      <NavigateToWaypoint x="24.0" y="0.0" theta="0.0"
                          description="go to docking station"/>
      <WaitForBatteryOK/>
    </Sequence>
  </BehaviorTree>

  <!-- ═══ TASK 5: Exit Building (5 marks) ═══ -->
  <BehaviorTree ID="Task5_ExitBuilding">
    <Sequence name="task5">
      <NavigateToWaypoint x="2.9" y="17.0" theta="1.57"
                          description="go to exit"/>
      <WaitSeconds duration="2.0"/>
    </Sequence>
  </BehaviorTree>

</root>
